generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUBSCRIBER
  ADMIN
}

enum PlanType {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  LAPSED
  PAST_DUE
}

enum DrawMode {
  RANDOM
  ALGORITHMIC
}

enum DrawStatus {
  DRAFT
  SIMULATED
  PUBLISHED
}

enum VerificationStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

enum PayoutStatus {
  PENDING
  PAID
}

enum DonationType {
  SUBSCRIPTION
  INDEPENDENT
}

model User {
  id                 String            @id @default(cuid())
  email              String            @unique
  passwordHash       String
  fullName           String
  role               UserRole          @default(SUBSCRIBER)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  charityPreference  CharityPreference?
  subscriptions      Subscription[]
  scores             ScoreEntry[]
  drawResults        DrawResult[]
  winnerProofs       WinnerProof[]
  independentDonations Donation[]      @relation("UserDonations")
}

model Charity {
  id                String             @id @default(cuid())
  name              String
  slug              String             @unique
  description       String
  imageUrl          String?
  upcomingEvents    Json?
  isFeatured        Boolean            @default(false)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  preferences       CharityPreference[]
  donations         Donation[]
}

model CharityPreference {
  id                  String    @id @default(cuid())
  userId              String    @unique
  charityId           String
  contributionPercent Int       @default(10)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  charity             Charity   @relation(fields: [charityId], references: [id], onDelete: Restrict)
}

model Subscription {
  id                String             @id @default(cuid())
  userId            String
  plan              PlanType
  status            SubscriptionStatus @default(ACTIVE)
  amount            Decimal            @db.Decimal(10, 2)
  charityPercent    Int                @default(10)
  provider          String             @default("stripe")
  providerRef       String?
  startedAt         DateTime           @default(now())
  renewalDate       DateTime
  canceledAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  donations         Donation[]

  @@index([userId, status])
}

model ScoreEntry {
  id        String   @id @default(cuid())
  userId    String
  score     Int
  playedOn  DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, playedOn(sort: Desc)])
}

model Draw {
  id                   String      @id @default(cuid())
  monthKey             String      @unique
  mode                 DrawMode
  status               DrawStatus  @default(DRAFT)
  winningNumbers       Json
  totalPool            Decimal     @db.Decimal(12, 2)
  fiveMatchPool        Decimal     @db.Decimal(12, 2)
  fourMatchPool        Decimal     @db.Decimal(12, 2)
  threeMatchPool       Decimal     @db.Decimal(12, 2)
  rolloverFromPrevious Decimal     @default(0) @db.Decimal(12, 2)
  simulatedAt          DateTime?
  publishedAt          DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  results              DrawResult[]
}

model DrawResult {
  id                 String             @id @default(cuid())
  drawId             String
  userId             String
  matchedCount       Int
  prizeAmount        Decimal            @db.Decimal(12, 2)
  verificationStatus VerificationStatus @default(NOT_REQUIRED)
  payoutStatus       PayoutStatus?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  draw               Draw               @relation(fields: [drawId], references: [id], onDelete: Cascade)
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  proof              WinnerProof?

  @@unique([drawId, userId])
  @@index([userId, matchedCount])
}

model WinnerProof {
  id           String             @id @default(cuid())
  drawResultId String             @unique
  userId       String
  proofUrl     String
  status       VerificationStatus @default(PENDING)
  reviewNotes  String?
  reviewedBy   String?
  submittedAt  DateTime           @default(now())
  reviewedAt   DateTime?
  drawResult   DrawResult         @relation(fields: [drawResultId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Donation {
  id             String       @id @default(cuid())
  userId         String
  charityId      String
  subscriptionId String?
  type           DonationType
  amount         Decimal      @db.Decimal(10, 2)
  recordedAt     DateTime     @default(now())
  user           User         @relation("UserDonations", fields: [userId], references: [id], onDelete: Cascade)
  charity        Charity      @relation(fields: [charityId], references: [id], onDelete: Restrict)
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([charityId, recordedAt])
}
