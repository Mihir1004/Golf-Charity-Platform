# Neon / Vercel pooled URL for Prisma runtime queries.
POSTGRES_PRISMA_URL="postgresql://username:password@ep-your-host-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Neon / Vercel non-pooled URL for Prisma direct migrations.
POSTGRES_URL_NON_POOLING="postgresql://username:password@ep-your-host.region.aws.neon.tech/neondb?sslmode=require"

# Optional compatibility aliases if you use scripts expecting these keys.
DATABASE_URL="postgresql://username:password@ep-your-host-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://username:password@ep-your-host.region.aws.neon.tech/neondb?sslmode=require"

JWT_SECRET="replace-with-a-32-char-random-secret"
APP_URL="http://localhost:3000"
